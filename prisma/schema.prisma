generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Branches (sucursales)
model Branch {
  id          String      @id @default(cuid())
  name        String      @unique
  address     String?
  inventories Inventory[]
  admins      Admin[]
  cashSessions CashSession[]
  createdAt   DateTime    @default(now())
}

// Inventory — stock por sucursal
model Inventory {
  id        Int      @id @default(autoincrement())
  productId String
  branchId  String
  stock     Int      @default(0)

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId])
}

// Products
model Product {
  id          String      @id
  name        String
  description String?
  price       Float
  cost        Float?
  category    String
  image       String?
  badge       String?
  features    String[]
  gallery     String[]
  swatches    Json        @default("[]")
  reviews     Json        @default("[]")
  highlights  Json        @default("[]")
  details      String?
  howToUse     String?
  shippingInfo String?
  highlightsLabel String?
  highlightsTitle String?
  scienceTitle    String?
  scienceDesc     String?
  scienceItems    Json        @default("[]")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  inventories Inventory[]
}

// Orders
model Order {
  id             String      @id
  customer       String
  email          String
  total          Float
  subtotal       Float
  shipping       Float       @default(0)
  tax            Float       @default(0)
  status         String      @default("pending")
  shippingMethod String?
  paymentMethod  String?
  address        String?
  notes          String?
  /** Sucursal desde donde se despachó/retiró el pedido (para restaurar stock en cancelaciones) */
  branchId       String?
  cashSessionId  String?
  date           DateTime    @default(now())
  items          OrderItem[]
  cashSession    CashSession? @relation(fields: [cashSessionId], references: [id])
}

model CashSession {
  id                    String         @id @default(cuid())
  branchId              String
  adminId               String
  status                String         @default("OPEN") // OPEN, CLOSED
  openingBalance        Float
  expectedClosingBalance Float         @default(0)
  actualClosingBalance  Float?
  difference            Float?
  notes                 String?
  openedAt              DateTime       @default(now())
  closedAt              DateTime?
  
  branch                Branch         @relation(fields: [branchId], references: [id])
  admin                 Admin          @relation(fields: [adminId], references: [id])
  movements             CashMovement[]
  orders                Order[]
}

model CashMovement {
  id          String      @id @default(cuid())
  sessionId   String
  type        String      // IN, OUT
  amount      Float
  reason      String
  orderId     String?
  createdAt   DateTime    @default(now())
  
  session     CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id        Int    @id @default(autoincrement())
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// Pages
model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  blocks    Json     @default("[]")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Settings (single row)
model Settings {
  id   Int  @id @default(1)
  data Json
}

// Tutorials (single row)
model Tutorials {
  id   Int  @id @default(1)
  data Json
}

// Newsletter subscribers
model NewsletterSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  phone     String?
  message   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum AdminRole {
  ADMIN
  VENDEDOR
}

// Admins
model Admin {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      AdminRole @default(ADMIN)
  branchId  String?
  branch    Branch?   @relation(fields: [branchId], references: [id])
  cashSessions CashSession[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}